# REQUIRED
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# SECURITY
ENCRYPTION_KEY=64_hex_chars_exactly_256_bits_minimum_entropy_required
ENCRYPTION_KEY_OLD=
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# AI
GROQ_API_KEY=your-groq-api-key
# Groq production models verified against the official Groq docs on 2026-03-31.
# The retired legacy 8B Groq model was replaced with `llama-3.1-8b-instant`.
# The older 3.1 70B versatile model was retired on 2025-01-24, so quality defaults to 3.3 70B.
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_SMART=llama-3.3-70b-versatile
GROQ_MODEL_QUALITY=llama-3.3-70b-versatile
OPENAI_API_KEY=your-openai-api-key

# QUEUE
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=5

# PAYMENTS
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# OBSERVABILITY - optional but recommended for production QUEUE mon
SENTRY_DSN=
APP_VERSION=1.0.0

# SERVER
PORT=3001
NODE_ENV=production
TZ=UTC
FRONTEND_URL=https://your-app.vercel.app
CORS_ORIGINS=https://your-app.vercel.app
